  secLbl('ORDER SUMMARY \u00B7 SAMSUNG SHOP');
  var finalPaid=isNew?'Rs.1,13,999':'Rs.1,15,599';
  var totalSaved=isNew?'Rs.20,999':'Rs.19,400';
  var pct=isNew?'15.7%':'14.4%';
  var cardBenefit=isNew?'5% HDFC electronics offer':'2% cashback \u2014 ICICI Amazon Pay';
  var cardBenefitVal=isNew?'\u2212 Rs.5,440':'\u2212 Rs.2,400';
  var cardColor=isNew?'#C9A84C':'#FF6B00';

  var rows=[
    {l:'Samsung Galaxy S25 Ultra (MRP)',v:'Rs.1,34,999',c:'#1C2B4A'},
    {l:'Bank offer \u2014 Electronics',v:'\u2212 Rs.15,000',c:'#00875A'},
    {l:'Coupon: DHURDEAL',v:'\u2212 Rs.2,000',c:'#00875A'},
    {l:cardBenefit,v:cardBenefitVal,c:cardColor},
  ];
  var rw=document.createElement('div');rw.style.marginBottom='18px';
  rows.forEach(function(r,i){
    var row=document.createElement('div');row.className='crow';row.id='cr'+i;row.style.opacity='0';
    row.innerHTML='<span class="cl">'+r.l+'</span><span class="cv" style="color:'+r.c+'">'+r.v+'</span>';
    rw.appendChild(row);
  });
  feed.appendChild(rw);
  for(var i=0;i<4;i++){await wait(1100);document.getElementById('cr'+i).style.opacity='1';goBottom();}
  await wait(800);
  chime('complete');
  await agentMsg('Order confirmed! Samsung Galaxy S25 Ultra delivers to your Mumbai address tomorrow. You saved '+totalSaved+' in total \u2014 '+pct+' off the walk-in price. Mission accomplished. \uD83C\uDF89',true);
  await wait(600);

  var cbkStat=isNew?'Rs.560 pts + 5% offer':'Rs.2,400 cashback';
  var cbkColor=isNew?'#C9A84C':'#FF6B00';
  var sum=document.createElement('div');sum.className='summary';
  sum.innerHTML='<div class="sum-h"><div class="sum-ck">&#10003;</div>'+
    '<div><div class="sum-t">Mission Accomplished</div><div class="sum-s">Samsung Galaxy S25 Ultra \u00B7 Delivering tomorrow</div></div></div>'+
    '<div class="stats">'+
    '<div class="stat"><div class="sl">YOU PAID</div><div class="sv" style="color:#1C2B4A">'+finalPaid+'</div></div>'+
    '<div class="stat"><div class="sl">YOU SAVED</div><div class="sv" style="color:#00875A">'+totalSaved+'</div></div>'+
    '<div class="stat"><div class="sl">CARD BENEFIT</div><div class="sv" style="color:'+cbkColor+'">'+cbkStat+'</div></div>'+
    '</div><div class="tot"><span class="tl">Total benefit vs. walk-in price</span><span class="tv">'+totalSaved+' \u00B7 '+pct+' off</span></div>';
  feed.appendChild(sum);goBottom();
}
</script>
