<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>DHURANDHAR Commerce Agent</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}
body{background:#F0F4FA;color:#1C2B4A;font-family:'Plus Jakarta Sans',sans-serif;-webkit-font-smoothing:antialiased}

@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
@keyframes cardFlip{from{opacity:0;transform:perspective(600px) rotateY(-16deg) scale(0.94)}to{opacity:1;transform:perspective(600px) rotateY(0) scale(1)}}
@keyframes popIn{0%{opacity:0;transform:scale(0.93)}100%{opacity:1;transform:scale(1)}}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.5}}

/* ══ TWO-PANE SHELL ══ */
.app{display:flex;height:100vh;overflow:hidden}

/* LEFT PANE */
.pane-left{
  width:280px;flex-shrink:0;
  display:flex;flex-direction:column;
  background:white;
  border-right:1px solid #DDE3EE;
  height:100vh;
  overflow:hidden;
}
.pl-header{
  padding:14px 16px 12px;
  border-bottom:1px solid #EEF1F7;
  display:flex;align-items:center;gap:9px;
  flex-shrink:0;
}
.logo-icon{width:30px;height:30px;border-radius:8px;background:linear-gradient(135deg,#8B1A00,#C83200);display:flex;align-items:center;justify-content:center;color:#FFD700;font-size:11px;font-weight:800;box-shadow:0 3px 8px rgba(139,26,0,0.3);font-family:'JetBrains Mono',monospace}
.logo-name{font-size:12px;font-weight:800;color:#1C2B4A;letter-spacing:0.3px}
.logo-sub{font-size:7px;color:#8B1A00;letter-spacing:2px;font-family:'JetBrains Mono',monospace}

.pl-body{
  flex:1;overflow-y:auto;padding:16px;
  display:flex;flex-direction:column;align-items:center;
}
.pl-body::-webkit-scrollbar{width:3px}
.pl-body::-webkit-scrollbar-thumb{background:#E0E6F0;border-radius:2px}

/* Mascot in left pane */
.mascot-wrap{text-align:center;margin-bottom:14px;animation:float 3.5s ease-in-out infinite}
.mascot-label{font-size:13px;font-weight:800;color:#1C2B4A;margin-top:6px;letter-spacing:0.3px}
.mascot-label span{color:#8B1A00}
.mascot-tag{font-size:9px;color:#8FA3C0;font-family:'JetBrains Mono',monospace;letter-spacing:1px;margin-top:2px}

/* Left pane pre-send welcome text */
.pl-welcome{font-size:12px;color:#5A7090;line-height:1.65;text-align:center;padding:0 4px;margin-bottom:14px}
.pl-hint{font-size:10px;color:#A0B4C8;font-family:'JetBrains Mono',monospace;text-align:center;line-height:1.5}

/* Left pane post-send: query display + status */
.query-display{
  width:100%;background:#FFF5F0;border:1px solid #FFD0C0;
  border-radius:12px;padding:12px 14px;margin-bottom:14px;
  animation:fadeUp 0.4s ease;
}
.query-display-lbl{font-size:9px;font-weight:700;color:#8B1A00;letter-spacing:2px;margin-bottom:6px;font-family:'JetBrains Mono',monospace}
.query-display-txt{font-size:12px;color:#3A1A08;line-height:1.6;font-weight:500}

.status-box{
  width:100%;background:#F5F7FA;border:1px solid #DDE3EE;
  border-radius:10px;padding:10px 12px;
  animation:fadeUp 0.4s ease;
}
.status-lbl{font-size:8px;font-weight:700;color:#8FA3C0;letter-spacing:2px;margin-bottom:5px;font-family:'JetBrains Mono',monospace}
.status-stage{font-size:13px;font-weight:700;color:#1C2B4A}
.status-dot{display:inline-block;width:7px;height:7px;border-radius:50%;background:#8B1A00;margin-right:6px;animation:pulse 1.4s ease-in-out infinite}

/* LEFT FOOTER — single input */
.pl-footer{
  flex-shrink:0;padding:12px 14px;
  border-top:1px solid #EEF1F7;
  background:white;
}
.input-row{display:flex;gap:8px;align-items:flex-end}
.chat-input{
  flex:1;border:1.5px solid #C8D4E8;border-radius:12px;
  padding:10px 12px;font-size:13px;color:#1C2B4A;
  font-family:'Plus Jakarta Sans',sans-serif;
  background:white;outline:none;resize:none;
  line-height:1.5;max-height:90px;
  box-shadow:0 2px 6px rgba(28,43,74,0.07);
  transition:border-color 0.2s;
}
.chat-input:focus{border-color:#8B1A00}
.chat-input:disabled{background:#F5F7FA;color:#A0B4C8;cursor:not-allowed}
.send-btn{
  width:38px;height:38px;border-radius:10px;border:none;
  background:linear-gradient(135deg,#8B1A00,#C83200);
  color:#FFD700;cursor:pointer;flex-shrink:0;
  box-shadow:0 3px 8px rgba(139,26,0,0.3);
  transition:transform 0.15s;
  display:flex;align-items:center;justify-content:center;
  -webkit-tap-highlight-color:transparent;
}
.send-btn:active{transform:scale(0.93)}
.send-btn:disabled{opacity:0.4;cursor:default}

/* RIGHT PANE */
.pane-right{
  flex:1;display:flex;flex-direction:column;
  overflow:hidden;background:#F0F4FA;
}
.pr-stage-bar{
  flex-shrink:0;padding:10px 20px;
  border-bottom:1px solid #DDE3EE;
  background:rgba(240,244,250,0.97);backdrop-filter:blur(12px);
  display:flex;align-items:center;gap:4px;
}
.sp{font-size:8px;font-weight:600;letter-spacing:0.5px;padding:3px 8px;border-radius:20px;font-family:'JetBrains Mono',monospace;color:#9AABC0;background:#E8EDF5;border:1px solid #DDE3EE;transition:all 0.5s;white-space:nowrap}
.sp.active{color:#8B1A00;background:#FFF0E8;border-color:#FFB899}
.sp.done{color:#00875A;background:#E6F7F1;border-color:#A8DECA}
.ss{width:10px;height:1.5px;background:#DDE3EE;flex-shrink:0;transition:background 0.5s}
.ss.done{background:#00875A}

.pr-feed{flex:1;overflow-y:auto;padding:20px 22px 40px}
.pr-feed::-webkit-scrollbar{width:4px}
.pr-feed::-webkit-scrollbar-track{background:transparent}
.pr-feed::-webkit-scrollbar-thumb{background:#C8D4E8;border-radius:2px}

/* Right pane welcome */
.pr-welcome{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  height:100%;text-align:center;padding:40px 30px;
  color:#8FA3C0;
}
.pr-welcome-icon{font-size:36px;margin-bottom:16px;opacity:0.5}
.pr-welcome-txt{font-size:14px;color:#8FA3C0;line-height:1.7;max-width:280px}

/* ══ CHAT MESSAGES ══ */
.msg{display:flex;gap:9px;margin-bottom:14px;animation:fadeUp 0.4s ease;max-width:640px}
.msg.user{flex-direction:row-reverse}
.av{width:28px;height:28px;border-radius:50%;flex-shrink:0;margin-top:2px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800}
.av.ag{background:linear-gradient(135deg,#8B1A00,#C83200);color:#FFD700;box-shadow:0 2px 6px rgba(139,26,0,0.25)}
.av.ok{background:linear-gradient(135deg,#00875A,#006644);color:white;box-shadow:0 2px 6px rgba(0,135,90,0.22)}
.av.us{background:#1C2B4A;color:white}
.bbl{padding:10px 14px;border-radius:14px;max-width:86%;font-size:13px;line-height:1.72}
.bbl.ag{background:white;border:1px solid #DDE3EE;border-radius:3px 14px 14px 14px;color:#2C3E5A;font-family:'JetBrains Mono',monospace;box-shadow:0 2px 8px rgba(28,43,74,0.06)}
.bbl.us{background:linear-gradient(135deg,#8B1A00,#B02800);color:white;border-radius:14px 3px 14px 14px;font-size:13px;font-weight:500;box-shadow:0 2px 10px rgba(139,26,0,0.25)}
.cur{animation:blink 0.7s step-end infinite;color:#8B1A00}

/* Section label */
.sec{font-size:8px;font-weight:700;color:#8FA3C0;letter-spacing:2.5px;margin:14px 0 10px 2px;font-family:'JetBrains Mono',monospace;animation:fadeUp 0.4s ease}

/* ══ PHONE GRID ══ */
.pgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-bottom:6px;max-width:640px}
.pc{background:white;border-radius:13px;padding:13px;border:2px solid #DDE3EE;box-shadow:0 2px 8px rgba(28,43,74,0.06);transition:all 0.4s;position:relative;cursor:pointer;animation:fadeUp 0.4s ease both;-webkit-tap-highlight-color:transparent}
.pc.sel{border-color:#8B1A00;box-shadow:0 5px 18px rgba(139,26,0,0.18);transform:translateY(-3px)}
.pc-badge{position:absolute;top:8px;right:8px;background:#8B1A00;color:#FFD700;font-size:8px;font-weight:700;padding:2px 6px;border-radius:20px}
.sel-ring{display:none;position:absolute;top:8px;left:8px;width:18px;height:18px;border-radius:50%;background:#8B1A00;color:#FFD700;font-size:9px;font-weight:700;align-items:center;justify-content:center}
.pc.sel .sel-ring{display:flex}
.pc-em{font-size:20px;margin-bottom:7px}
.pc-nm{font-size:11px;font-weight:700;color:#1C2B4A;margin-bottom:3px;line-height:1.4}
.pc-mrp{font-size:9px;color:#A0B4C8;text-decoration:line-through;font-family:'JetBrains Mono',monospace}
.pc-pr{font-size:15px;font-weight:800}
.pc-of{font-size:9px;color:#C05000;font-weight:600;margin-top:4px;line-height:1.4}
.sb{margin-top:8px;height:3px;background:#EEF1F7;border-radius:10px}
.sf{height:100%;border-radius:10px;width:0%;transition:width 1.4s ease}
.st{font-size:8px;color:#A0B4C8;margin-top:3px;font-family:'JetBrains Mono',monospace}

/* ══ CONFIRM BTN ══ */
.conf-btn{width:100%;max-width:640px;border:none;border-radius:12px;padding:13px;font-size:14px;font-weight:700;color:#FFD700;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;background:linear-gradient(135deg,#8B1A00,#C83200);box-shadow:0 4px 16px rgba(139,26,0,0.28);margin-top:10px;margin-bottom:16px;animation:fadeUp 0.4s ease;transition:transform 0.15s;-webkit-tap-highlight-color:transparent}
.conf-btn:active{transform:scale(0.98)}
.conf-btn:disabled{opacity:0.45;cursor:default}

/* ══ 3-CARD GRID ══ */
.card3-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;margin-bottom:8px;max-width:640px;animation:fadeUp 0.5s ease}
.ccard{background:white;border-radius:13px;padding:14px;border:2px solid #DDE3EE;box-shadow:0 2px 8px rgba(28,43,74,0.06);transition:all 0.4s;cursor:pointer;position:relative;overflow:visible;animation:fadeUp 0.4s ease both;-webkit-tap-highlight-color:transparent}
.ccard.ncs{border-color:#C9A84C;background:linear-gradient(160deg,#FFFDF5,white)}
.ccard.sel{border-color:#8B1A00;box-shadow:0 5px 18px rgba(139,26,0,0.18);transform:translateY(-3px)}
.ccard.ncs.sel{border-color:#C9A84C;box-shadow:0 5px 20px rgba(201,168,76,0.28);transform:translateY(-3px)}
.top-badge{position:absolute;top:-1px;left:50%;transform:translateX(-50%);font-size:8px;font-weight:700;padding:3px 10px;border-radius:0 0 10px 10px;white-space:nowrap;letter-spacing:0.3px}
.tbg{background:linear-gradient(135deg,#C9A84C,#E8C060);color:#5A3A00}
.ccard-type{display:inline-block;font-size:8px;font-weight:700;padding:2px 7px;border-radius:8px;margin-bottom:7px;margin-top:3px}
.ccard-bank{font-size:9px;font-weight:600;color:#8FA3C0;margin-bottom:2px}
.ccard-name{font-size:11px;font-weight:700;color:#1C2B4A;margin-bottom:8px;line-height:1.3}
.ccard-row{display:flex;justify-content:space-between;align-items:flex-start;padding:5px 7px;border-radius:7px;margin-bottom:3px;background:#F5F7FA;gap:4px}
.ccard-rl{font-size:8px;color:#5A7090;font-weight:500;flex-shrink:0;line-height:1.4}
.ccard-rv{font-size:8px;font-weight:700;text-align:right;line-height:1.4}
.ccard-total{margin-top:7px;padding:8px 7px;border-radius:9px;text-align:center}
.ccard-tl{font-size:7px;font-weight:700;color:#8FA3C0;letter-spacing:1px;margin-bottom:2px}
.ccard-tv{font-size:16px;font-weight:800}

/* ══ APPLY STEPS ══ */
.astep{display:flex;align-items:center;gap:11px;padding:11px 14px;margin-bottom:7px;background:white;border-radius:11px;border:1px solid #DDE3EE;box-shadow:0 1px 5px rgba(28,43,74,0.05);transition:opacity 0.5s;max-width:640px}
.astep.dim{opacity:0.3}
.dot{width:28px;height:28px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;border:2px solid #DDE3EE;background:#F0F4FA;transition:all 0.4s}
.dot.done{background:#E6F7F1;border-color:#00875A;color:#00875A;font-size:13px}
.dot.active{background:#FFF0E8;border-color:#8B1A00}
.dl{font-size:13px;font-weight:600;color:#1C2B4A}
.ds{font-size:10px;color:#8FA3C0;font-family:'JetBrains Mono',monospace;margin-top:1px}

/* ══ VIRTUAL CARD ══ */
.vcard-outer{max-width:280px;margin:18px 0}
.vcard{border-radius:16px;padding:20px 18px 16px;background:linear-gradient(135deg,#1a3060,#0d1e45,#1a2e58);border:1px solid rgba(255,255,255,0.1);box-shadow:0 12px 40px rgba(0,0,0,0.22);position:relative;overflow:hidden;animation:cardFlip 0.8s cubic-bezier(0.34,1.4,0.64,1)}
.vcard-glow{position:absolute;top:-22px;right:-22px;width:90px;height:90px;border-radius:50%;background:radial-gradient(circle,rgba(201,168,76,0.18),transparent)}
.vc-bank{font-size:10px;font-weight:700;color:#C9A84C;letter-spacing:1.5px}
.vc-num{font-size:13px;color:#7A9ABB;letter-spacing:3px;margin:14px 0;font-family:'JetBrains Mono',monospace}
.vc-bot{display:flex;justify-content:space-between;align-items:flex-end}
.vc-fl{font-size:7px;color:#4A6880;letter-spacing:2px;margin-bottom:2px}
.vc-fv{font-size:11px;color:#C0D0E0;font-weight:700}
.vc-bar{position:absolute;bottom:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#C9A84C,#FFE082,#C9A84C)}

/* ══ OTP ══ */
.otp-card{background:white;border-radius:16px;border:1.5px solid #DDE3EE;overflow:hidden;box-shadow:0 6px 28px rgba(28,43,74,0.1);animation:popIn 0.5s cubic-bezier(0.34,1.4,0.64,1);margin-bottom:10px;max-width:480px}
.otp-hdr{background:#1A1F71;padding:14px 18px;display:flex;align-items:center;gap:11px}
.mc-r{width:24px;height:24px;border-radius:50%;background:#EB001B;flex-shrink:0}
.mc-y{width:24px;height:24px;border-radius:50%;background:#F79E1B;opacity:0.95;margin-left:-8px;flex-shrink:0}
.otp-ht{font-size:12px;font-weight:700;color:white}
.otp-hs{font-size:9px;color:rgba(255,255,255,0.6);font-family:'JetBrains Mono',monospace;margin-top:1px}
.otp-body{padding:18px}
.otp-merch{display:flex;justify-content:space-between;padding:9px 12px;background:#F5F7FA;border-radius:10px;margin-bottom:14px;border:1px solid #EEF1F7}
.otp-ml{font-size:9px;color:#8FA3C0;font-weight:600;margin-bottom:2px}
.otp-mv{font-size:13px;font-weight:700;color:#1C2B4A}
.otp-info{font-size:12px;color:#3A5070;line-height:1.65;margin-bottom:14px}
.otp-info strong{color:#1C2B4A}
.otp-fields{display:flex;gap:7px;justify-content:center;margin-bottom:12px}
.otp-box{width:38px;height:46px;border:2px solid #C8D4E8;border-radius:10px;font-size:20px;font-weight:700;color:#1C2B4A;text-align:center;font-family:'JetBrains Mono',monospace;background:white;outline:none;transition:border-color 0.2s;-webkit-appearance:none}
.otp-box:focus{border-color:#8B1A00;box-shadow:0 0 0 3px rgba(139,26,0,0.1)}
.otp-box.filled{border-color:#8B1A00;background:#FFF5F0}
.otp-hint{font-size:10px;color:#8FA3C0;text-align:center;margin-bottom:14px;font-family:'JetBrains Mono',monospace}
.otp-hint a{color:#8B1A00;font-weight:600;text-decoration:none}
.otp-sub{width:100%;border:none;border-radius:10px;padding:13px;font-size:14px;font-weight:700;color:white;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;background:linear-gradient(135deg,#1A1F71,#0D1255);box-shadow:0 3px 14px rgba(26,31,113,0.28);transition:transform 0.15s;-webkit-tap-highlight-color:transparent}
.otp-sub:active{transform:scale(0.98)}
.otp-sub:disabled{opacity:0.45;cursor:default}
.otp-foot{padding:10px 18px;border-top:1px solid #EEF1F7;display:flex;align-items:center;gap:6px;background:#FAFBFD}
.otp-fl{font-size:9px;color:#8FA3C0;font-family:'JetBrains Mono',monospace}
.mc-badge{margin-left:auto;display:flex;align-items:center;gap:3px;font-size:8px;color:#1A1F71;font-weight:700;letter-spacing:0.5px}

/* ══ CHECKOUT ROWS ══ */
.crow{display:flex;justify-content:space-between;align-items:center;padding:10px 14px;margin-bottom:6px;border-radius:11px;background:white;border:1px solid #DDE3EE;box-shadow:0 1px 4px rgba(28,43,74,0.05);transition:opacity 0.5s;max-width:640px}
.cl{font-size:12px;color:#5A7090;font-family:'JetBrains Mono',monospace}
.cv{font-size:12px;font-weight:700}

/* ══ SUMMARY ══ */
.summary{background:white;border-radius:16px;overflow:hidden;border:1.5px solid #A8DECA;box-shadow:0 6px 28px rgba(0,135,90,0.1);animation:popIn 0.6s cubic-bezier(0.34,1.4,0.64,1);margin-top:4px;max-width:640px}
.sum-h{background:linear-gradient(135deg,#00875A,#006644);padding:18px 20px;display:flex;align-items:center;gap:11px}
.sum-ck{width:40px;height:40px;border-radius:50%;background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;font-size:18px}
.sum-t{font-size:17px;font-weight:800;color:white}
.sum-s{font-size:10px;color:rgba(255,255,255,0.7);margin-top:2px;font-family:'JetBrains Mono',monospace}
.stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;padding:16px 18px 0}
.stat{text-align:center;padding:12px 6px;background:#F5F7FA;border-radius:11px;border:1px solid #EEF1F7}
.sl{font-size:8px;font-weight:700;color:#8FA3C0;letter-spacing:2px;margin-bottom:5px;font-family:'JetBrains Mono',monospace}
.sv{font-size:16px;font-weight:800}
.tot{margin:12px 18px 16px;padding:11px 14px;border-radius:11px;background:#F0F4FA;border:1px solid #DDE3EE;display:flex;justify-content:space-between;align-items:center}
.tl{font-size:11px;color:#5A7090;font-family:'JetBrains Mono',monospace}
.tv{font-size:14px;font-weight:800;color:#00875A}

.hidden{display:none}

/* ══ MOBILE LAYOUT ══ */
@media(max-width:700px){
  .app{flex-direction:column}
  .pane-left{width:100%;height:auto;flex-direction:row;align-items:center;gap:8px;padding:10px 14px;border-right:none;border-bottom:1px solid #DDE3EE}
  .pl-header{border:none;padding:0;flex-shrink:0}
  .pl-body{display:none}
  .pl-footer{flex:1;padding:0;border:none}
  .pane-right{flex:1;min-height:0;overflow:hidden}
  .pgrid,.card3-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>
<div class="app">

  <!-- ══════════════════════════════════ -->
  <!--        LEFT PANE                  -->
  <!-- ══════════════════════════════════ -->
  <div class="pane-left">

    <div class="pl-header">
      <div class="logo-icon">DH</div>
      <div>
        <div class="logo-name">DHURANDHAR</div>
        <div class="logo-sub">COMMERCE AGENT</div>
      </div>
    </div>

    <div class="pl-body" id="plBody">
      <!-- Mascot -->
      <div class="mascot-wrap">
        <svg width="76" height="108" viewBox="0 0 90 128" fill="none" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="45" cy="124" rx="22" ry="4" fill="#1C2B4A" opacity="0.12"/>
          <path d="M18 70 Q14 80 12 110 L78 110 Q76 80 72 70 Q60 62 45 62 Q30 62 18 70Z" fill="#1C2B4A"/>
          <path d="M40 62 L45 80 L50 62" fill="none" stroke="#8B1A00" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="40" y1="62" x2="50" y2="62" stroke="#8B1A00" stroke-width="1" opacity="0.6"/>
          <line x1="38" y1="72" x2="36" y2="108" stroke="#2C3E5A" stroke-width="0.8" opacity="0.5"/>
